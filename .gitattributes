# Auto detect text files and normalize to LF
* text=auto eol=lf

# JavaScript / TypeScript
*.js      text
*.jsx     text
*.ts      text
*.tsx     text
*.mjs     text
*.cjs     text

# Styles
*.css     text
*.scss    text
*.sass    text
*.less    text

# Markup
*.html    text
*.json    text
*.md      text
*.mdx     text
*.yml     text
*.yaml    text

# Config
*.env.example text
*.gitignore text
*.gitattributes text
*.editorconfig text

# Shell scripts
*.sh      text eol=lf

# Windows scripts
*.bat     text eol=crlf
*.cmd     text eol=crlf
*.ps1     text eol=crlf

# Images
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.svg     text
*.ico     binary

# Fonts
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary

# Archives
*.zip     binary
*.tar     binary
*.gz      binary
*.7z      binary

# Documents
*.pdf     binary

# Lock files
package-lock.json text
pnpm-lock.yaml text
yarn.lock text
bun.lock text
bun.lockb binary
